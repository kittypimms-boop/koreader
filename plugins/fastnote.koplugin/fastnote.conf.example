-- fastnote.koplugin — user configuration
--
-- HOW TO ACTIVATE
-- ---------------
-- Copy (or rename) this file to:
--
--   koreader/settings/fastnote.conf
--
-- On a Kobo device that is usually:
--   /mnt/onboard/.adds/koreader/settings/fastnote.conf
--
-- Edit the values below, then restart KOReader.
-- Missing keys fall back to the built-in defaults shown here.

return {

    -- finger_draw
    -- -----------
    -- Allow drawing with finger (capacitive touch) in addition to the pen.
    --
    --   false  (default) — pen-only mode.
    --              Capacitive touch events are ignored while the raw pen
    --              driver is active, so accidental palm / finger marks
    --              cannot appear.  Recommended for normal use.
    --
    --   true   — pen + finger both draw.
    --              Useful for testing in the SDL emulator (which has no
    --              Wacom digitizer and falls back to the gesture path), or
    --              if you prefer sketching with your finger.
    --
    finger_draw = false,

    -- rotation_mode
    -- -------------
    -- Screen orientation when the canvas opens.  The canvas locks to this
    -- orientation and ignores accelerometer-based auto-rotation while it is
    -- open; you can still change orientation from the in-canvas menu.
    --
    --   "auto"  (default) — inherit whatever orientation is currently active
    --              when the canvas opens.  This is the recommended default.
    --
    --   0       — always open in portrait (upright).
    --   3       — always open in landscape with buttons at the bottom
    --              (counter-clockwise rotation — recommended for Kobo Libra).
    --   1       — landscape with buttons at the top (clockwise rotation).
    --   2       — portrait upside-down.
    --
    rotation_mode = "auto",

    -- debug_input_log
    -- ---------------
    -- Write a timestamped raw + decoded event log to fastnote/input.log.
    -- Useful for diagnosing eraser detection, hover glitches, and other
    -- hardware input issues.  Tail the log over SSH:
    --
    --   tail -F /mnt/onboard/.adds/koreader/fastnote/input.log
    --
    -- Also togglable live from the hamburger menu ("Debug log: off/on")
    -- without restarting KOReader.
    --
    --   false  (default) — logging off.  No overhead at runtime.
    --   true   — log enabled on canvas open.
    --
    debug_input_log = false,

    -- tighten_delay
    -- -------------
    -- Seconds of pen inactivity after which the deferred colour "tighten"
    -- pass fires: a single targeted GLRC16 refresh over the accumulated
    -- stroke bounding box, revealing true ink colour (Kaleido 3). Only
    -- active on colour hardware; ignored on monochrome / emulator.
    --
    --   2.5  (default) — matches the device-tuned constant. This value was
    --              tuned on real hardware: lowering it risks firing the
    --              tighten pass mid-multi-stroke writing, which briefly
    --              locks out the pen. If you change it, re-run the
    --              multi-stroke writing test from the
    --              waveform-experimentation skill.
    --
    tighten_delay = 2.5,

    -- tighten_enabled
    -- ---------------
    -- Whether to perform the deferred colour tighten pass.
    --
    --   true   (default) — A2 strokes tighten into full colour
    --              ~tighten_delay seconds after the pen lifts.
    --   false  — draw-time A2 only; no deferred colour pass.
    --              Use if you find the periodic refresh distracting.
    --
    tighten_enabled = true,

    -- live_color_refresh
    -- -------------------
    -- Replaces the per-segment "a2" (grayscale) live refresh with a
    -- throttled direct Screen:refreshUI call over the accumulated dirty
    -- rect (~30 fps cap), bypassing UIManager entirely. Shows live ink
    -- colour while drawing instead of grayscale; the tighten pass above
    -- still fires afterwards for full colour fidelity.
    --
    -- Only takes effect when colour hardware AND the raw evdev pen path are
    -- both in use — the gesture/emulator path and monochrome hardware are
    -- never affected by this flag, regardless of its value.
    --
    -- This value is only the STARTING state when the canvas opens. During
    -- the session it is auto-toggled: picking a non-black ink colour turns
    -- it on, picking black or entering dark mode turns it off (see
    -- canvas_utils.auto_live_color_refresh) — neither black-only ink nor
    -- dark-mode ink (always shown solid white/black regardless of this
    -- flag) benefits from it. It can also still be flipped manually from
    -- the hamburger menu ("Live color ink (experimental)") as an explicit
    -- override after the fact; that toggle, like the auto-behaviour, is
    -- session-only and does not persist back to this file.
    --
    --   false  (default) — unchanged behaviour: per-segment "a2" refresh.
    --   true   — shows live ink colour while drawing.
    --
    live_color_refresh = false,

    -- eraser_button
    -- -------------
    -- Which raw button code the Kobo Stylus 2's hardware eraser tip sends
    -- on your unit. The eraser tip reports as `BTN_STYLUS` (a level
    -- signal: on while touching, off on release) on standard units, but
    -- some units/pens ship with `BTN_STYLUS` and `BTN_STYLUS2` (the side
    -- button) swapped.
    --
    --   "stylus"   (default) — eraser tip sends BTN_STYLUS. Standard wiring.
    --   "stylus2"  — eraser tip sends BTN_STYLUS2. Try this if the eraser
    --                end of your stylus draws instead of erasing — that
    --                symptom means your unit has the two swapped.
    --
    -- The other (non-configured) code is always treated as the side button:
    -- ignored for drawing/erasing, logged at debug level only.
    --
    eraser_button = "stylus",

    -- live_ink_style
    -- --------------
    -- How live (in-progress) strokes paint into the display while the pen
    -- is moving, on colour hardware (Kaleido 3). Never affects StrokeBuffer
    -- -- the stroke's true colour is always recorded regardless of this
    -- setting (ADR-002); this only changes what's shown before the tighten
    -- pass reveals it.
    --
    --   "solid"  (default) -- live segments draw as solid black (dark mode:
    --              white, which is already solid) instead of the chosen ink
    --              colour. Matches the stock Kobo notebook app's look and
    --              avoids the A2 live-drawing waveform's 1-bit thresholding
    --              turning light ink colours into a faint, sparse dither
    --              while writing. True colour appears once the tighten
    --              pass fires (see tighten_delay above).
    --   "color"  -- live segments draw the true ink colour (pre-Task-C2
    --              behaviour). Symptom: colour ink looks faint / dotted
    --              while actively drawing -- especially for lighter
    --              colours -- until the tighten pass fires.
    --
    -- Ignored (no behaviour change) on monochrome hardware, whenever the
    -- live_color_refresh experiment above is active (that path shows true
    -- colour live on purpose, so it always wins over "solid"), and when
    -- tighten_enabled = false (with no tighten pass, nothing would ever
    -- repaint the true colour back over the solid ink).
    --
    live_ink_style = "solid",

}
